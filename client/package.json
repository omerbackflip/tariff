    "html2pdf.js": "^0.10.3",
    "material-design-icons-iconfont": "^6.1.0",
    "moment": "^2.29.1",
    "papaparse": "^5.3.1",
    "vue": "^2.6.11",
    "vue-csv-import": "^3.3.10",
    "vue-excel-export": "^0.1.3",
    "vue-picture-swipe": "^2.1.0",
    "vue-router": "^3.5.2",
    "vuetify": "^2.4.0"
  },
  "devDependencies": {
    "@vue/cli-plugin-babel": "~4.5.0",
    "@vue/cli-plugin-eslint": "~4.5.0",
    "@vue/cli-service": "~4.5.0",
    "babel-eslint": "^10.1.0",
    "cross-env": "^7.0.3",
    "eslint": "^6.7.2",
    "eslint-plugin-vue": "^6.2.2",
